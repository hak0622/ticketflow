# MySQL
MYSQL_ROOT_PASSWORD=rootpassword
DB_USERNAME=bloguser
DB_PASSWORD=blogpassword

# JWT (base64 인코딩된 32바이트 이상 문자열)
# 생성 방법: openssl rand -base64 32
JWT_SECRET_KEY=your-base64-encoded-secret-key-here

# Google OAuth2 (https://console.cloud.google.com 에서 발급)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Toss 결제 테스트 키 (https://developers.tosspayments.com 에서 발급)
TOSS_SECRET_KEY=test_sk_your_toss_secret_key
